{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPBeam",
  "identifier": "com.gpbeam.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popover",
        "title": "GPBeam",
        "width": 320,
        "height": 420,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "popover.html"
      },
      {
        "label": "settings",
        "title": "GPBeam Settings",
        "width": 720,
        "height": 540,
        "decorations": true,
        "resizable": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' tauri:; style-src 'self' tauri: 'unsafe-inline'; img-src 'self' asset: data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
