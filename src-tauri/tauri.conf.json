{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GPBeam",
  "version": "0.1.0",
  "identifier": "com.gpbeam.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popover",
        "title": "GPBeam",
        "width": 320,
        "height": 420,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "popover.html"
      },
      {
        "label": "settings",
        "title": "GPBeam Settings",
        "width": 720,
        "height": 540,
        "decorations": true,
        "resizable": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
